-- ========== AUTO FINISH WORLDS (with BrokenWalls tracking) ==========
local autoFinishEnabled = false
local autoFinishCoroutine = nil

-- Helper: check if all worlds are unlocked (WorldsUnlocked >= 8)
local function isAllWorldsUnlocked()
    local worldsUnlocked = LocalPlayer:GetAttribute("WorldsUnlocked")
    return worldsUnlocked and worldsUnlocked >= 8
end

-- Parse BrokenWalls attribute into a set (table with wall names as keys)
local function getBrokenWallsSet()
    local brokenStr = LocalPlayer:GetAttribute("BrokenWalls")
    if not brokenStr or brokenStr == "" then
        return {}
    end
    local brokenSet = {}
    for wall in string.gmatch(brokenStr, "[^,]+") do
        brokenSet[wall] = true
    end
    return brokenSet
end

-- Get a list of all wall names (assuming Wall1 to Wall21, but we'll detect from folder)
local function getAllWallNames()
    local wallsFolder = workspace:FindFirstChild("Walls")
    if not wallsFolder then return {} end
    local names = {}
    for _, child in ipairs(wallsFolder:GetChildren()) do
        if child:IsA("BasePart") and child.Name:match("Wall%d+") then
            table.insert(names, child.Name)
        end
    end
    table.sort(names, function(a, b)
        local numA = tonumber(a:match("%d+")) or 0
        local numB = tonumber(b:match("%d+")) or 0
        return numA < numB
    end)
    return names
end

-- Get a specific wall part by name
local function getWallPart(wallName)
    local wallsFolder = workspace:FindFirstChild("Walls")
    if wallsFolder then
        return wallsFolder:FindFirstChild(wallName)
    end
    return nil
end

-- Teleport to a target (CFrame, part, or model)
local function teleportToTarget(target)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local targetCF = nil
    if type(target) == "userdata" and target:IsA("CFrame") then
        targetCF = target + Vector3.new(0, 3, 0)
    elseif target:IsA("BasePart") then
        targetCF = target.CFrame + Vector3.new(0, 3, 0)
    elseif target:IsA("Model") then
        local primary = target.PrimaryPart
        if primary and primary:IsA("BasePart") then
            targetCF = primary.CFrame + Vector3.new(0, 3, 0)
        else
            targetCF = target:GetPivot() + Vector3.new(0, 3, 0)
        end
    else
        return false
    end
    
    hrp.CFrame = targetCF
    return true
end

local function runAutoFinish()
    local allWallNames = getAllWallNames()
    if #allWallNames == 0 then
        WindUI:Notify({ Title = "Auto Finish", Content = "No walls found. Stopping.", Duration = 2 })
        autoFinishEnabled = false
        return
    end

    while autoFinishEnabled do
        -- Get current broken walls set
        local brokenSet = getBrokenWallsSet()
        local allBroken = true

        -- Teleport to each unbroken wall in order
        for _, wallName in ipairs(allWallNames) do
            if not autoFinishEnabled then break end

            if not brokenSet[wallName] then
                -- Wall not broken yet, teleport to it
                local wallPart = getWallPart(wallName)
                if wallPart and wallPart.Parent then
                    teleportToTarget(wallPart)
                    task.wait(0.8) -- Give more time for the wall to break
                    -- After teleport, re-check broken walls set
                    brokenSet = getBrokenWallsSet()
                else
                    -- Wall part missing; assume it's broken
                end
            end

            -- After processing, check if this wall is now broken
            if not brokenSet[wallName] then
                allBroken = false
            end
        end

        if not autoFinishEnabled then break end

        -- If all walls are now broken, teleport to the hardcoded portal position
        if allBroken then
            teleportToTarget(PORTAL_POSITION)
            WindUI:Notify({ Title = "Auto Finish", Content = "World completed! Teleported to portal.", Duration = 1 })
            task.wait(2) -- Wait for the world to transition

            -- Now check if all worlds are unlocked
            if isAllWorldsUnlocked() then
                WindUI:Notify({ Title = "Auto Finish", Content = "All worlds unlocked. Stopping.", Duration = 2 })
                break
            end
            -- If not, loop again to process the next world
        else
            -- Some walls still broken? Wait a bit and loop again
            task.wait(1)
        end
    end
    autoFinishEnabled = false
    if uiRefs.AutoFinishToggle then
        uiRefs.AutoFinishToggle:Set(false)
    end
end

local function startAutoFinish()
    if isAllWorldsUnlocked() then
        WindUI:Notify({ Title = "Auto Finish", Content = "All worlds already unlocked. Cannot start.", Duration = 2 })
        return
    end
    if autoFinishCoroutine then
        stopAutoFinish()
    end
    autoFinishEnabled = true
    autoFinishCoroutine = coroutine.create(runAutoFinish)
    coroutine.resume(autoFinishCoroutine)
    WindUI:Notify({ Title = "Auto Finish", Content = "Started", Duration = 2 })
end

local function stopAutoFinish()
    autoFinishEnabled = false
    if autoFinishCoroutine then
        autoFinishCoroutine = nil
    end
    WindUI:Notify({ Title = "Auto Finish", Content = "Stopped", Duration = 2 })
end

