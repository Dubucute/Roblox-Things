-- Farming state
local farmingActive = false
local farmingCoroutine = nil

local function stopFarming()
    farmingActive = false
    if farmingCoroutine then
        farmingCoroutine = nil
    end
    -- Do NOT update toggles here to avoid recursion
end

local function safeWait(seconds)
    local start = tick()
    while tick() - start < seconds do
        if not farmingActive then break end
        task.wait(0.1)
    end
end

local function startFarmingNames(selectedNames, mutationList)
    if farmingActive then stopFarming() end
    farmingActive = true
    farmingCoroutine = coroutine.create(function()
        while farmingActive do
            for _, name in ipairs(selectedNames) do
                if not farmingActive then break end
                local entries = brainrotCacheByName[name] or {}
                -- Filter by mutations
                if not tableContains(mutationList, "All") then
                    local filtered = {}
                    for _, entry in ipairs(entries) do
                        local mut = entry.mutation or "Normal"
                        if tableContains(mutationList, mut) then
                            table.insert(filtered, entry)
                        end
                    end
                    entries = filtered
                end
                if #entries == 0 then
                    safeWait(0.5)
                else
                    local model = entries[1].model
                    teleportToBrainrot(model)
                    interactWithBrainrot(model)
                    goToSafeZone()
                end
                task.wait(0.1)
            end
            task.wait(0.5)
        end
    end)
    coroutine.resume(farmingCoroutine)
end

local function startFarmingRarity(rarity, mutationList)
    if farmingActive then stopFarming() end
    farmingActive = true
    farmingCoroutine = coroutine.create(function()
        while farmingActive do
            local entries = brainrotCacheByRarity[rarity] or {}
            if not tableContains(mutationList, "All") then
                local filtered = {}
                for _, entry in ipairs(entries) do
                    local mut = entry.mutation or "Normal"
                    if tableContains(mutationList, mut) then
                        table.insert(filtered, entry)
                    end
                end
                entries = filtered
            end
            if #entries == 0 then
                safeWait(1)
            else
                for _, entry in ipairs(entries) do
                    if not farmingActive then break end
                    local model = entry.model
                    teleportToBrainrot(model)
                    interactWithBrainrot(model)
                    task.wait(0.3)
                    goToSafeZone()
                    task.wait(0.1)
                end
            end
            task.wait(0.5)
        end
    end)
    coroutine.resume(farmingCoroutine)
end

