local function teleportToCoordinates(coordsStr)
    local x, y, z = coordsStr:match("([%-%d.]+)%s*[,%s]%s*([%-%d.]+)%s*[,%s]%s*([%-%d.]+)")
    if not x then
        -- try space separated
        x, y, z = coordsStr:match("([%-%d.]+)%s+([%-%d.]+)%s+([%-%d.]+)")
    end
    if x and y and z then
        x, y, z = tonumber(x), tonumber(y), tonumber(z)
        if x and y and z then
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = CFrame.new(x, y, z)
                WindUI:Notify({ Title = "Teleport", Content = "Teleported to " .. string.format("%.1f, %.1f, %.1f", x, y, z), Duration = 2 })
            else
                WindUI:Notify({ Title = "Error", Content = "Character not found.", Duration = 2 })
            end
            return
        end
    end
    WindUI:Notify({ Title = "Error", Content = "Invalid coordinates. Use format: x, y, z or x y z", Duration = 3 })
end

