configTab:Paragraph({ Title = "Configuration", Desc = "Save, load, and manage configs." })

if hasFileSupport then
    local currentConfigName = "settings"
    local configDropdown = nil
    local newConfigName = ""

    local function getConfigNames()
        local folder = "DubuHub/GetStrong/config"
        if not isfolder(folder) then makefolder(folder) end
        local files = listfiles(folder)
        local names = {}
        for _, file in ipairs(files) do
            local name = file:match("([^/\\]+)%.json$")
            if name then
                table.insert(names, name)
            end
        end
        table.sort(names)
        return names
    end

    local function refreshConfigList()
        local names = getConfigNames()
        if configDropdown then
            configDropdown:Refresh(names)
            if table.find(names, currentConfigName) then
                configDropdown:Select(currentConfigName)
            else
                configDropdown:Select(nil)
            end
        end
    end

    local function saveCurrentConfig()
        local data = {
            instantPromptsEnabled = instantPromptsEnabled,
            antiAFKEnabled = antiAFKEnabled,
            autoFinishEnabled = autoFinishEnabled,
            -- Player settings
            walkspeed = uiRefs.sliders.Walkspeed and uiRefs.sliders.Walkspeed.Value or 16,
            jumppower = uiRefs.sliders.JumpPower and uiRefs.sliders.JumpPower.Value or 50,
            gravity = uiRefs.sliders.Gravity and uiRefs.sliders.Gravity.Value or 196.2,
            time = uiRefs.sliders.Time and uiRefs.sliders.Time.Value or 12,
            infiniteJump = uiRefs.toggles.InfiniteJump and uiRefs.toggles.InfiniteJump.Value or false,
            noclip = uiRefs.toggles.Noclip and uiRefs.toggles.Noclip.Value or false,
        }
        local json = HttpService:JSONEncode(data)
        local folder = "DubuHub/GetStrong/config"
        if not isfolder(folder) then makefolder(folder) end
        local file = folder .. "/" .. currentConfigName .. ".json"
        writefile(file, json)
    end

    configDropdown = configTab:Dropdown({
        Title = "Config List",
        Desc = "Select a config to load/save",
        Values = {},
        Multi = false,
        Default = nil,
        Callback = function(selected)
            if selected then
                currentConfigName = selected
            end
        end
    })

    configTab:Input({
        Title = "New Config Name",
        Desc = "Enter name for new config",
        Value = "",
        Type = "Input",
        Placeholder = "e.g., myconfig",
        Callback = function(input)
            newConfigName = input
        end
    })

    configTab:Button({
        Title = "New Config",
        Desc = "Create a new config with the entered name",
        Callback = function()
            if newConfigName and newConfigName ~= "" then
                currentConfigName = newConfigName
                saveCurrentConfig()
                refreshConfigList()
                WindUI:Notify({ Title = "Config", Content = "Created: " .. currentConfigName, Duration = 2 })
            else
                WindUI:Notify({ Title = "Config", Content = "Please enter a name", Duration = 2 })
            end
        end
    })

    configTab:Button({
        Title = "Save Config",
        Desc = "Save current settings to the selected config",
        Callback = function()
            saveCurrentConfig()
            refreshConfigList()
            WindUI:Notify({ Title = "Config", Content = "Saved to " .. currentConfigName, Duration = 2 })
        end
    })

    configTab:Button({
        Title = "Load Config",
        Desc = "Load settings from the selected config",
        Callback = function()
            local folder = "DubuHub/GetStrong/config"
            local file = folder .. "/" .. currentConfigName .. ".json"
            if not isfile(file) then
                WindUI:Notify({ Title = "Config", Content = "File not found", Duration = 2 })
                return
            end
            local json = readfile(file)
            local data = HttpService:JSONDecode(json)

            instantPromptsEnabled = data.instantPromptsEnabled or false
            toggleInstantPrompts(instantPromptsEnabled)
            if uiRefs.InstantPromptsToggle then uiRefs.InstantPromptsToggle:Set(instantPromptsEnabled) end

            antiAFKEnabled = data.antiAFKEnabled or false
            toggleAntiAFK(antiAFKEnabled)
            if uiRefs.AntiAFKToggle then uiRefs.AntiAFKToggle:Set(antiAFKEnabled) end

            -- Auto finish
            if data.autoFinishEnabled and not isAllWorldsUnlocked() then
                startAutoFinish()
                if uiRefs.AutoFinishToggle then uiRefs.AutoFinishToggle:Set(true) end
            else
                stopAutoFinish()
                if uiRefs.AutoFinishToggle then uiRefs.AutoFinishToggle:Set(false) end
            end

            -- Player settings
            if uiRefs.sliders.Walkspeed then uiRefs.sliders.Walkspeed:Set(data.walkspeed or 16) end
            if uiRefs.sliders.JumpPower then uiRefs.sliders.JumpPower:Set(data.jumppower or 50) end
            if uiRefs.sliders.Gravity then uiRefs.sliders.Gravity:Set(data.gravity or 196.2) end
            if uiRefs.sliders.Time then uiRefs.sliders.Time:Set(data.time or 12) end
            if uiRefs.toggles.InfiniteJump then uiRefs.toggles.InfiniteJump:Set(data.infiniteJump or false) end
            if uiRefs.toggles.Noclip then uiRefs.toggles.Noclip:Set(data.noclip or false) end

            WindUI:Notify({ Title = "Config", Content = "Loaded from " .. currentConfigName, Duration = 2 })
        end
    })

    configTab:Button({
        Title = "Delete Config",
        Desc = "Delete the selected config (cannot be undone)",
        Callback = function()
            if currentConfigName == "settings" then
                WindUI:Notify({ Title = "Config", Content = "Cannot delete default 'settings'", Duration = 2 })
                return
            end
            local folder = "DubuHub/GetStrong/config"
            local file = folder .. "/" .. currentConfigName .. ".json"
            if isfile(file) then
                delfile(file)
                refreshConfigList()
                currentConfigName = "settings"
                if configDropdown then configDropdown:Select("settings") end
                WindUI:Notify({ Title = "Config", Content = "Deleted", Duration = 2 })
            else
                WindUI:Notify({ Title = "Config", Content = "File not found", Duration = 2 })
            end
        end
    })

    configTab:Button({
        Title = "Refresh List",
        Desc = "Manually refresh the config list",
        Callback = function()
            refreshConfigList()
            WindUI:Notify({ Title = "Config", Content = "List refreshed", Duration = 1 })
        end
    })

    configTab:Button({
        Title = "Reset to Defaults",
        Desc = "Reset all settings to default values (current config not saved)",
        Callback = function()
            instantPromptsEnabled = false; toggleInstantPrompts(false); if uiRefs.InstantPromptsToggle then uiRefs.InstantPromptsToggle:Set(false) end
            antiAFKEnabled = false; toggleAntiAFK(false); if uiRefs.AntiAFKToggle then uiRefs.AntiAFKToggle:Set(false) end
            stopAutoFinish(); if uiRefs.AutoFinishToggle then uiRefs.AutoFinishToggle:Set(false) end
            -- Player defaults
            if uiRefs.sliders.Walkspeed then uiRefs.sliders.Walkspeed:Set(16) end
            if uiRefs.sliders.JumpPower then uiRefs.sliders.JumpPower:Set(50) end
            if uiRefs.sliders.Gravity then uiRefs.sliders.Gravity:Set(196.2) end
            if uiRefs.sliders.Time then uiRefs.sliders.Time:Set(12) end
            if uiRefs.toggles.InfiniteJump then uiRefs.toggles.InfiniteJump:Set(false) end
            if uiRefs.toggles.Noclip then uiRefs.toggles.Noclip:Set(false) end
            WindUI:Notify({ Title = "Config", Content = "Reset to defaults", Duration = 2 })
        end
    })

    -- Auto-load default config on startup
    task.spawn(function()
        task.wait(0.5)
        local folder = "DubuHub/GetStrong/config"
        local file = folder .. "/settings.json"
        if isfile(file) then
            local json = readfile(file)
            local data = HttpService:JSONDecode(json)

            instantPromptsEnabled = data.instantPromptsEnabled or false
            toggleInstantPrompts(instantPromptsEnabled)
            if uiRefs.InstantPromptsToggle then uiRefs.InstantPromptsToggle:Set(instantPromptsEnabled) end

            antiAFKEnabled = data.antiAFKEnabled or false
            toggleAntiAFK(antiAFKEnabled)
            if uiRefs.AntiAFKToggle then uiRefs.AntiAFKToggle:Set(antiAFKEnabled) end

            if data.autoFinishEnabled and not isAllWorldsUnlocked() then
                startAutoFinish()
                if uiRefs.AutoFinishToggle then uiRefs.AutoFinishToggle:Set(true) end
            else
                stopAutoFinish()
                if uiRefs.AutoFinishToggle then uiRefs.AutoFinishToggle:Set(false) end
            end

            if uiRefs.sliders.Walkspeed then uiRefs.sliders.Walkspeed:Set(data.walkspeed or 16) end
            if uiRefs.sliders.JumpPower then uiRefs.sliders.JumpPower:Set(data.jumppower or 50) end
            if uiRefs.sliders.Gravity then uiRefs.sliders.Gravity:Set(data.gravity or 196.2) end
            if uiRefs.sliders.Time then uiRefs.sliders.Time:Set(data.time or 12) end
            if uiRefs.toggles.InfiniteJump then uiRefs.toggles.InfiniteJump:Set(data.infiniteJump or false) end
            if uiRefs.toggles.Noclip then uiRefs.toggles.Noclip:Set(data.noclip or false) end
        end
    end)
else
    configTab:Paragraph({
        Title = "Saving Unavailable",
        Desc = "Your executor does not support file functions. Config saving is disabled."
    })
end

-- ========== CLEANUP ==========
local function cleanup()
    if promptConnection then promptConnection:Disconnect() end
    if antiAFKConnection then antiAFKConnection:Disconnect() end
    if infiniteJumpConnection then infiniteJumpConnection:Disconnect() end
    if noclipConnection then noclipConnection:Disconnect() end
    stopAutoFinish()
end

RunService.Stepped:Connect(function() end)

-- ========== FINALIZE ==========
Window:SetToggleKey(Enum.KeyCode.LeftAlt)
WindUI:Notify({ Title = "Dubu Hub", Content = "Loaded! Press Left Alt to toggle UI.", Duration = 3 })
print("Dubu Hub v7.4 (Hardcoded portal) loaded.")

return { cleanup = cleanup }
