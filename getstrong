local SAFEZONE_POS = Vector3.new(102.1, 3.8, 6.5)

-- Cache tables
local brainrotCacheByName = {}
local brainrotCacheByRarity = {}
local function rebuildBrainrotCache()
    brainrotCacheByName = {}
    brainrotCacheByRarity = {}
    local folder = workspace:FindFirstChild("Brainrots")
    if not folder then return end
    for _, model in ipairs(folder:GetChildren()) do
        if model:IsA("Model") then
            local name = model:GetAttribute("OriginalName")
            local rarity = model:GetAttribute("Rarity")
            local mutation = model:GetAttribute("Mutation") -- store mutation
            if name then
                if not brainrotCacheByName[name] then brainrotCacheByName[name] = {} end
                table.insert(brainrotCacheByName[name], {model = model, mutation = mutation})
            end
            if rarity then
                if not brainrotCacheByRarity[rarity] then brainrotCacheByRarity[rarity] = {} end
                table.insert(brainrotCacheByRarity[rarity], {model = model, mutation = mutation})
            end
        end
    end
end

-- Update cache dynamically
local function onBrainrotAdded(model)
    if not model:IsA("Model") then return end
    local name = model:GetAttribute("OriginalName")
    local rarity = model:GetAttribute("Rarity")
    local mutation = model:GetAttribute("Mutation")
    if name then
        if not brainrotCacheByName[name] then brainrotCacheByName[name] = {} end
        table.insert(brainrotCacheByName[name], {model = model, mutation = mutation})
    end
    if rarity then
        if not brainrotCacheByRarity[rarity] then brainrotCacheByRarity[rarity] = {} end
        table.insert(brainrotCacheByRarity[rarity], {model = model, mutation = mutation})
    end
end

local function onBrainrotRemoved(model)
    local name = model:GetAttribute("OriginalName")
    local rarity = model:GetAttribute("Rarity")
    if name and brainrotCacheByName[name] then
        for i, entry in ipairs(brainrotCacheByName[name]) do
            if entry.model == model then
                table.remove(brainrotCacheByName[name], i)
                break
            end
        end
        if #brainrotCacheByName[name] == 0 then brainrotCacheByName[name] = nil end
    end
    if rarity and brainrotCacheByRarity[rarity] then
        for i, entry in ipairs(brainrotCacheByRarity[rarity]) do
            if entry.model == model then
                table.remove(brainrotCacheByRarity[rarity], i)
                break
            end
        end
        if #brainrotCacheByRarity[rarity] == 0 then brainrotCacheByRarity[rarity] = nil end
    end
end

-- Set up cache monitoring
local brainrotFolder = workspace:FindFirstChild("Brainrots")
if brainrotFolder then
    rebuildBrainrotCache()
    brainrotFolder.ChildAdded:Connect(onBrainrotAdded)
    brainrotFolder.ChildRemoved:Connect(onBrainrotRemoved)
else
    workspace.ChildAdded:Connect(function(child)
        if child.Name == "Brainrots" then
            rebuildBrainrotCache()
            child.ChildAdded:Connect(onBrainrotAdded)
            child.ChildRemoved:Connect(onBrainrotRemoved)
        end
    end)
end

