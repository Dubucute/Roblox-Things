status.Text = "Detecting game..."
TweenService:Create(status, TweenInfo.new(0.35), { TextTransparency = 0 }):Play()
TweenService:Create(barFill, TweenInfo.new(0.4), { Size = UDim2.fromScale(0.25, 1) }):Play()
task.wait(0.3)

local scriptUrl = SUPPORTED_GAMES[game.PlaceId]

if scriptUrl then
    status.Text = "Downloading..."
    TweenService:Create(barFill, TweenInfo.new(0.7), { Size = UDim2.fromScale(0.75, 1) }):Play()

    local success, scriptContent = pcall(game.HttpGet, game, scriptUrl)

    if success and scriptContent then
        status.Text = "Ready!"
        TweenService:Create(barFill, TweenInfo.new(0.35), { Size = UDim2.fromScale(1, 1) }):Play()
        playSound(9120386435)
        task.wait(0.5)
        popOut()
        loadstring(scriptContent)()
    else
        status.Text = "Failed to load"
        TweenService:Create(barFill, TweenInfo.new(0.3), { Size = UDim2.fromScale(1, 1) }):Play()
        warn("Failed to load script:", scriptContent)
        task.wait(3)
    end
else
    status.Text = "Unsupported game"
    warn("Unsupported game: " .. gameName .. " (Place ID: " .. game.PlaceId .. ")")
    task.wait(3)
end

gui:Destroy()
