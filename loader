-- ===== FUNCTIONS =====

local function getGameName()
    local success, info = pcall(function()
        return MarketplaceService:GetProductInfo(game.PlaceId)
    end)
    if success and info then
        -- GetProductInfo returns a table keyed by PlaceId when given a single ID
        local data = info[game.PlaceId]
        if data and data.Name then
            return data.Name
        end
    end
    return "Unknown Game"
end

local function playSound(id)
    pcall(function()
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://" .. tostring(id)
        sound.Volume = 1
        sound.Parent = gui
        sound:Play()
        task.delay(3, function() sound:Destroy() end)
    end)
end

local function popOut()
    -- Pop out: scale up + fade together
    TweenService:Create(blur, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Size = 0 }):Play()
    TweenService:Create(overlay, TweenInfo.new(0.35), { BackgroundTransparency = 1 }):Play()
    TweenService:Create(container, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), { Size = UDim2.fromOffset(380, 260), BackgroundTransparency = 1 }):Play()
    TweenService:Create(iconCircle, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), { Size = UDim2.fromOffset(90, 90), BackgroundTransparency = 1 }):Play()
    for _, el in container:GetChildren() do
        if el:IsA("TextLabel") then
            TweenService:Create(el, TweenInfo.new(0.3), { TextTransparency = 1 }):Play()
        elseif el:IsA("Frame") and el ~= container and el ~= iconCircle then
            TweenService:Create(el, TweenInfo.new(0.3), { BackgroundTransparency = 1 }):Play()
        end
    end
    if border then TweenService:Create(border, TweenInfo.new(0.3), { Transparency = 1 }):Play() end
    task.wait(0.5)
    gui:Destroy()
end

-- ========== MAIN ==========

-- Entrance: icon zooms in from big → normal
